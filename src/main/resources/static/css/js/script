// ===== FUNCIÓN VOLVER (NUEVA) =====
// Función para volver a la página anterior
function goBack() {
    window.history.back();
}

// Función para ir al inicio (dashboard)
function goHome() {
    window.location.href = '/';
}

// ===== FUNCIONES EXISTENTES =====

// Confirmación para eliminar
function confirmarEliminar(mensaje) {
    return confirm(mensaje || '¿Estás seguro de eliminar este registro?');
}

// Formatear moneda
function formatearMoneda(valor) {
    return new Intl.NumberFormat('es-GT', {
        style: 'currency',
        currency: 'GTQ',
        minimumFractionDigits: 2
    }).format(valor);
}

// Mostrar notificación temporal
function mostrarNotificacion(mensaje, tipo = 'success') {
    const notificacion = document.createElement('div');
    notificacion.className = `alert alert-${tipo} alert-dismissible fade show position-fixed`;
    notificacion.style.top = '20px';
    notificacion.style.right = '20px';
    notificacion.style.zIndex = '9999';
    notificacion.style.minWidth = '250px';
    notificacion.style.borderRadius = '10px';
    notificacion.style.boxShadow = '0 4px 12px rgba(0,0,0,0.15)';

    let icono = '';
    if (tipo === 'success') icono = '<i class="fas fa-check-circle me-2"></i>';
    if (tipo === 'danger') icono = '<i class="fas fa-exclamation-circle me-2"></i>';
    if (tipo === 'warning') icono = '<i class="fas fa-exclamation-triangle me-2"></i>';
    if (tipo === 'info') icono = '<i class="fas fa-info-circle me-2"></i>';

    notificacion.innerHTML = `
        ${icono}${mensaje}
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    `;
    document.body.appendChild(notificacion);

    setTimeout(() => {
        notificacion.classList.add('fade');
        setTimeout(() => notificacion.remove(), 500);
    }, 3000);
}

// Validar formulario antes de enviar
function validarFormulario(formulario) {
    const inputs = formulario.querySelectorAll('input[required], select[required]');
    let valido = true;

    inputs.forEach(input => {
        if (!input.value.trim()) {
            input.classList.add('is-invalid');
            valido = false;
        } else {
            input.classList.remove('is-invalid');
        }
    });

    if (!valido) {
        mostrarNotificacion('Por favor completa todos los campos requeridos', 'danger');
    }

    return valido;
}

// Calcular subtotal (para detalle de ventas)
function calcularSubtotal(cantidad, precioUnitario) {
    return cantidad * precioUnitario;
}

// Actualizar total de venta (para detalle de ventas)
function actualizarTotalVenta() {
    let total = 0;
    document.querySelectorAll('.subtotal-input').forEach(input => {
        total += parseFloat(input.value) || 0;
    });
    document.getElementById('totalVenta').value = total.toFixed(2);
}

// Mostrar loading spinner
function mostrarLoading(mostrar) {
    let loading = document.getElementById('global-loading');
    if (mostrar) {
        if (!loading) {
            loading = document.createElement('div');
            loading.id = 'global-loading';
            loading.innerHTML = `
                <div style="position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); z-index: 9999;">
                    <div class="spinner-border text-success" role="status">
                        <span class="visually-hidden">Cargando...</span>
                    </div>
                </div>
                <div style="position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.3); z-index: 9998;"></div>
            `;
            document.body.appendChild(loading);
        }
    } else {
        if (loading) loading.remove();
    }
}

// Event listeners cuando el DOM está listo
document.addEventListener('DOMContentLoaded', function() {
    // Auto-cerrar alertas después de 3 segundos
    setTimeout(() => {
        document.querySelectorAll('.alert').forEach(alert => {
            if (alert.classList.contains('alert-dismissible')) {
                alert.remove();
            }
        });
    }, 3000);

    // Agregar efecto hover a las tarjetas
    document.querySelectorAll('.card').forEach(card => {
        card.addEventListener('mouseenter', () => {
            card.style.transform = 'translateY(-5px)';
        });
        card.addEventListener('mouseleave', () => {
            card.style.transform = 'translateY(0)';
        });
    });
});

// Exportar funciones para usar en otros scripts (si es necesario)
if (typeof module !== 'undefined' && module.exports) {
    module.exports = {
        goBack,
        goHome,
        confirmarEliminar,
        formatearMoneda,
        mostrarNotificacion,
        validarFormulario,
        mostrarLoading
    };
}